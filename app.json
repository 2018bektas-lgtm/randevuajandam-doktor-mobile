{
  "expo": {
    "name": "Randevu Ajandam Doktor",
    "slug": "randevuajandam-doktor-mobile",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "randevuajandam-doktor",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.randevuajandam.doktor",
      "infoPlist": {
        "NSCameraUsageDescription": "Randevu Ajandam Doktor, online görüşmeler için kameranıza erişmek ister.",
        "NSMicrophoneUsageDescription": "Randevu Ajandam Doktor, online görüşmeler için mikrofonunuza erişmek ister."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.randevuajandam.doktor",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#F4F6F9",
        "foregroundImage": "./assets/logo.png"
      },
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "randevuajandam-doktor"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "ndkVersion": "27.1.12297006",
            "kotlinVersion": "2.1.20",
            "buildArchs": ["arm64-v8a", "armeabi-v7a"],
            "packagingOptions": {
              "pickFirst": [
                "lib/x86/libc++_shared.so",
                "lib/x86_64/libc++_shared.so",
                "lib/armeabi-v7a/libc++_shared.so",
                "lib/arm64-v8a/libc++_shared.so"
              ]
            },
            "extraProguardRules": "-keep class com.revenuecat.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.swmansion.worklets.** { *; }"
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Randevu Ajandam Doktor, oturumunuzu korumak için Face ID erişimi ister."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Randevu Ajandam Doktor, galeri ve profil görselleri yüklemek için fotoğraflarınıza erişmek ister.",
          "cameraPermission": "Randevu Ajandam Doktor, profil fotoğrafı çekmek için kameranıza erişmek ister."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#F58A45",
          "defaultChannel": "randevu",
          "sounds": []
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "d08e9f79-bad1-4343-a31b-a6de02116ca9"
      },
      "appStoreId": "",
      "playPackageId": "com.randevuajandam.doktor",
      "privacyUrl": "https://randevuajandam.com/gizlilik-politikasi",
      "termsUrl": "https://randevuajandam.com/kullanim-kosullari",
      "kvkkUrl": "https://randevuajandam.com/kvkk",
      "revenueCatIosKey": "",
      "revenueCatAndroidKey": ""
    },
    "owner": "bektasozcetin"
  }
}
