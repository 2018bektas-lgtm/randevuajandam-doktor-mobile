# API
EXPO_PUBLIC_API_URL=https://randevuajandam.com/api/mobile/v1

# App Store Connect → App → Apple ID (numeric, e.g. 6471234567)
EXPO_PUBLIC_APP_STORE_ID=

# Play Console package (must match app.json android.package)
EXPO_PUBLIC_PLAY_PACKAGE_ID=com.randevuajandam.doktor

# Legal pages (live on site)
EXPO_PUBLIC_PRIVACY_URL=https://randevuajandam.com/gizlilik-politikasi
EXPO_PUBLIC_TERMS_URL=https://randevuajandam.com/kullanim-kosullari
EXPO_PUBLIC_KVKK_URL=https://randevuajandam.com/kvkk

# RevenueCat public SDK keys (Project settings → API keys)
# iOS: appl_...   Android: goog_...
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
