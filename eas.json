{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://randevuajandam.com/api/mobile/v1",
        "EXPO_PUBLIC_PRIVACY_URL": "https://randevuajandam.com/gizlilik-politikasi",
        "EXPO_PUBLIC_TERMS_URL": "https://randevuajandam.com/kullanim-kosullari",
        "EXPO_PUBLIC_PLAY_PACKAGE_ID": "com.randevuajandam.doktor",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://randevuajandam.com/api/mobile/v1",
        "EXPO_PUBLIC_PRIVACY_URL": "https://randevuajandam.com/gizlilik-politikasi",
        "EXPO_PUBLIC_TERMS_URL": "https://randevuajandam.com/kullanim-kosullari",
        "EXPO_PUBLIC_PLAY_PACKAGE_ID": "com.randevuajandam.doktor",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://randevuajandam.com/api/mobile/v1",
        "EXPO_PUBLIC_PRIVACY_URL": "https://randevuajandam.com/gizlilik-politikasi",
        "EXPO_PUBLIC_TERMS_URL": "https://randevuajandam.com/kullanim-kosullari",
        "EXPO_PUBLIC_PLAY_PACKAGE_ID": "com.randevuajandam.doktor",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://randevuajandam.com/api/mobile/v1",
        "EXPO_PUBLIC_PRIVACY_URL": "https://randevuajandam.com/gizlilik-politikasi",
        "EXPO_PUBLIC_TERMS_URL": "https://randevuajandam.com/kullanim-kosullari",
        "EXPO_PUBLIC_PLAY_PACKAGE_ID": "com.randevuajandam.doktor",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
